<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_channel_item"
    android:focusable="false">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/playlist_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_medium"
            android:textStyle="bold"
            tools:text="UK Channels" />

        <TextView
            android:id="@+id/playlist_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_small"
            android:ellipsize="end"
            android:singleLine="true"
            tools:text="http://example.com/playlist.m3u" />

        <TextView
            android:id="@+id/playlist_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_amber"
            android:textSize="@dimen/text_size_small"
            tools:text="Last updated: 10 mins ago" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_edit"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:src="@drawable/ic_edit"
        app:tint="@color/text_button_cyan"
        android:background="@drawable/bg_button_cyan"
        android:focusable="true"
        android:clickable="true"
        android:nextFocusRight="@+id/btn_delete"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/save" />

    <ImageView
        android:id="@+id/btn_delete"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:src="@drawable/ic_delete"
        app:tint="@color/text_button_amber"
        android:background="@drawable/bg_button_amber"
        android:focusable="true"
        android:clickable="true"
        android:nextFocusLeft="@+id/btn_edit"
        android:contentDescription="@string/delete" />

</LinearLayout>
