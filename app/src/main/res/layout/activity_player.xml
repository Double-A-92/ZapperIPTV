<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="surface_view" />

    <FrameLayout
        android:id="@+id/welcome_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginBottom="48dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_dpad_outer"
                    android:alpha="0.5"
                    android:contentDescription="@null" />
                <ImageView
                    android:id="@+id/welcome_dpad_inner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_dpad_inner"
                    android:alpha="0.9"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:id="@+id/welcome_instruction_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_instruction"
                android:textSize="24sp"
                android:textColor="#FF707070"
                android:letterSpacing="0.03"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/overlay_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_overlay"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/overlay_padding"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/overlay_channel_logo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:scaleType="centerInside"
            android:contentDescription="@null"
            tools:src="@drawable/ic_placeholder_logo" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/overlay_padding"
            android:orientation="vertical">

            <TextView
                android:id="@+id/overlay_channel_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="101" />

            <TextView
                android:id="@+id/overlay_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_large"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true"
                tools:text="BBC One HD" />

            <TextView
                android:id="@+id/overlay_programme_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                tools:text="Match of the Day"
                tools:visibility="visible" />

            <ProgressBar
                android:id="@+id/overlay_time_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:max="1000"
                android:progress="420"
                android:visibility="gone"
                android:indeterminate="false"
                android:layout_marginTop="4dp"
                android:progressTint="@color/accent_amber"
                android:progressBackgroundTint="@android:color/darker_gray"
                tools:visibility="visible" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/overlay_loading"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:indeterminateTint="@color/accent_amber"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>
    <FrameLayout
        android:id="@+id/channel_list_container"
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/background_overlay"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="@color/background_overlay">

            <ImageView
                android:id="@+id/playlist_nav_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_chevron_right"
                android:contentDescription="@string/playlist_prev"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:padding="8dp" />

            <TextView
                android:id="@+id/playlist_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:textAlignment="center"
                android:gravity="center"
                android:ellipsize="end"
                android:singleLine="true"
                android:maxLines="1"
                tools:text="All" />

            <ImageView
                android:id="@+id/playlist_nav_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_chevron_left"
                android:contentDescription="@string/playlist_next"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:padding="8dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="56dp"
            android:clipToPadding="false"
            android:padding="8dp"
            android:focusable="true"
            android:focusableInTouchMode="false" />

        <TextView
            android:id="@+id/favorites_empty_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="56dp"
            android:gravity="center"
            android:text="@string/favorites_empty_hint"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_medium"
            android:textAlignment="center"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/error_persistent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog"
        android:padding="24dp"
        android:textColor="@color/error_red"
        android:textSize="@dimen/text_size_medium"
        android:visibility="gone"
        tools:text="All channels failed to play." />

</FrameLayout>
