<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    android:padding="32dp">

    <!-- Decorative Top Accent Line to match the dialog -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/accent_cyan"
        android:layout_marginBottom="28dp"
        android:layout_marginStart="-32dp"
        android:layout_marginEnd="-32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/playlists"
        android:textSize="32sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/btn_add_url"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="@string/add_url"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/text_button_cyan"
            android:textStyle="bold"
            android:background="@drawable/bg_button_cyan"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/btn_reload"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="@string/reload"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/text_button_amber"
            android:textStyle="bold"
            android:background="@drawable/bg_button_amber"
            android:focusable="true"
            android:clickable="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/empty_playlists_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/empty_playlists_message"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:lineSpacingExtra="6dp"
        android:visibility="gone"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlist_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp" />

</LinearLayout>
