<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/channel_item_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_channel_item"
    android:focusable="true"
    android:clickable="true">

    <TextView
        android:id="@+id/channel_number"
        android:layout_width="@dimen/channel_number_width"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_medium"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        tools:text="101" />

    <View
        android:id="@+id/playlist_indicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginVertical="12dp"
        android:background="@color/channel_indicator_1" />

    <TextView
        android:id="@+id/channel_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_medium"
        android:ellipsize="end"
        android:singleLine="true"
        tools:text="BBC One HD" />

    <ImageView
        android:id="@+id/channel_logo"
        android:layout_width="@dimen/channel_logo_size"
        android:layout_height="@dimen/channel_logo_size"
        android:layout_marginStart="8dp"
        android:scaleType="centerInside"
        android:contentDescription="@null"
        tools:src="@drawable/ic_placeholder_logo" />

</LinearLayout>
